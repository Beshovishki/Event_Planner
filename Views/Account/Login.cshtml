@{
    ViewData["Title"] = "Вход";
}

<h2>Вход</h2>

<form asp-action="Login" method="post">
    <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" class="form-control" required />
    </div>

    <div class="form-group mt-2">
        <label>Парола</label>
        <input type="password" name="password" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-success mt-3">Влез</button>
</form>

<div class="mt-3">
    <a asp-action="Register">Нямате акаунт? Регистрация</a>
</div>

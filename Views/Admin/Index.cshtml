
@model IEnumerable<EventPlanner.Models.AppUser>

@{
    ViewData["Title"] = "Админ - Потребители";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<h2>Потребители</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Имейл</th>
            <th>Потребителско име</th>
            <th>Роля</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.UserName</td>
                <td>@user.Role</td>
                <td>
                    @* Бутон за редакция *@
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@user.Id">Edit</a>

                    @* Бутон за изтриване *@
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@user.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@* Бутон за добавяне на нов потребител *@
<a class="btn btn-success" asp-action="Create">Добави нов потребител</a>

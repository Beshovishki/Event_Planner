@model IEnumerable<EventPlanner.Models.AppUser>

@{
    ViewData["Title"] = "Admin Panel";
}

<h2>Admin Panel</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>User Id</th>
            <th>Email</th>
            <th>Username</th>
            <th>Role</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Email</td>
                    <td>@user.UserName</td>
                    <td>@user.Role</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center">No users found.</td>
            </tr>
        }
    </tbody>
</table>

@model EventPlanner.Models.AppUser

@{
    ViewBag.Title = "Редактирай потребител";
}

<h2>@ViewBag.Title</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="form-group">
    <label>Потребителско име</label>
    <input type="text" name="username" value="@Model.UserName" class="form-control" required />
</div>


    <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" value="@Model.Email" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Роля</label>
        <select asp-for="Role" class="form-control">
    @foreach (var role in ViewBag.Roles as List<Microsoft.AspNetCore.Identity.IdentityRole>)
    {
        if (Model.Role == role.Name)
        {
            <option value="@role.Name" selected>@role.Name</option>
        }
        else
        {
            <option value="@role.Name">@role.Name</option>
        }
    }
</select>

    </div>
    <button type="submit" class="btn btn-primary">Запази</button>
    <a asp-action="Index" class="btn btn-secondary">Откажи</a>
</form>
